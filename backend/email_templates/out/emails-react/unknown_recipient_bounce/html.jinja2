<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="x-apple-disable-message-reformatting" />
  </head>
  <body style="background-color:#F6F4EE;margin:0;padding:0;font-family:Georgia,'Times New Roman',serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F6F4EE;">
      <tbody>
        <tr>
          <td align="center" style="padding:40px 20px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;">
              <tbody>
                <tr>
                  <td style="padding-bottom:40px;">
                    <p style="font-family:Georgia,serif;font-size:22px;color:#0F2A3F;letter-spacing:1px;margin:0;">Sloopquest</p>
                  </td>
                </tr>
                <tr>
                  <td style="background:#FFFFFF;border:1px solid #E1DCD2;border-radius:16px;padding:48px 40px;">
                    <p style="font-family:Georgia,serif;font-size:26px;line-height:1.1;color:#0F2A3F;margin:0 0 20px 0;">Delivery failed</p>
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.6;color:#4F5F6B;margin:0 0 20px 0;">
                      Your message could not be delivered to <strong style="color:#0F2A3F;">{{ original_to }}</strong> because no such mailbox exists at sloopquest.com.
                    </p>
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.6;color:#4F5F6B;margin:0 0 20px 0;">
                      Please check the address and try again. If you believe this address should exist, contact the recipient through another channel.
                    </p>
                    <hr style="border:none;border-top:1px solid #E1DCD2;margin:28px 0;" />
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:500;color:#8A8378;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 8px 0;">
                      Original message
                    </p>
                    <div style="background:#FBFAF6;border:1px solid #E1DCD2;border-radius:12px;padding:14px 16px;">
                      <p style="font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:1.5;color:#4F5F6B;margin:0;">
                        <strong style="color:#0F2A3F;">To:</strong> {{ original_to }}<br />
                        <strong style="color:#0F2A3F;">Subject:</strong> {{ original_subject }}
                      </p>
                    </div>
                    <p style="font-family:Georgia,serif;font-size:16px;color:#0F2A3F;margin:32px 0 0 0;">
                      Fair winds,<br />
                      <span style="color:#A26A3A;">The Sloopquest Team</span>
                    </p>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-top:32px;">
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#8A8378;margin:0 0 4px 0;">© 2026 Sloopquest</p>
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#B5AFA7;margin:0;">
                      This is an automated message from the Sloopquest mail system.
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
