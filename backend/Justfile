# Sloopquest Justfile — https://just.systems

default:
    @just --list

# ─── Install ──────────────────────────────────────────────────────────────────

install:
    uv sync --dev

# ─── Database ─────────────────────────────────────────────────────────────────

db-start:
    docker compose -f docker-compose.dev.yml up -d

db-stop:
    docker compose -f docker-compose.dev.yml down

migrate:
    uv run alembic upgrade head

db-reset:
    docker compose -f docker-compose.dev.yml down -v
    just db-start
    just migrate

# ─── Development ──────────────────────────────────────────────────────────────

dev:
    uv run litestar --app app.index:app run -r -d -p 8000

dev-worker:
    uv run litestar --app app.index:app workers run

dev-emails:
    cd emails && pnpm dev

build-emails:
    cd emails && pnpm build

# ─── Tests ────────────────────────────────────────────────────────────────────

test:
    uv run pytest -v

# ─── Code Quality ─────────────────────────────────────────────────────────────

lint:
    uv run ruff check --fix . && uv run ruff format .

typecheck:
    uv run basedpyright
